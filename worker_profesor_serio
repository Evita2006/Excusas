import os
import time
import random

DIRECTORIO_TAREAS = "cola_de_tareas"

def procesar_excusa():
    while True:
        archivos = [f for f in os.listdir(DIRECTORIO_TAREAS) if f.startswith("procesando_")]
        
        if archivos:
            archivo = archivos[0]
            ruta = os.path.join(DIRECTORIO_TAREAS, archivo)
            
            # Leer el contenido de la excusa
            with open(ruta, "r", encoding="utf-8") as f:
                excusa_texto = f.read().strip()
            
            print(f"[PROFESOR SERIO] 👨‍🏫 Revisando excusa: \"{excusa_texto}\"")
            
            # Rechaza el 90% de las excusas
            if random.random() < 0.9:
                print(f"[PROFESOR SERIO] ❌ RECHAZADA: No me convence... Vuelve a intentarlo el próximo cuatrimestre.")
            else:
                print(f"[PROFESOR SERIO] ⚠️  ACEPTADA (excepcionalmente): Bueno... esta vez te dejo pasar.")
            
            # Eliminar la excusa procesada
            try:
                os.remove(ruta)
                print(f"[PROFESOR SERIO] 🗑️  Excusa {archivo} eliminada del sistema.")
            except FileNotFoundError:
                pass
        
        time.sleep(2)  # Más lento (serio = riguroso)

if __name__ == "__main__":
    print("[PROFESOR SERIO] 👨‍🏫 Listo para evaluar excusas...")
    procesar_excusa()
